# import libraries
import os
import numpy as np
import matplotlib.pyplot as plt
import pandas as pd


def circulation(x, z, u, w):
# this function calcultes the circulation by taking the line integral of the velocity field over the contour of the airfoil
# initiate circulation as gamma
    gamma = 0.0
    n = len(x)

    for i in range(n):
        # store the first data sets
        x1, z1 = x[i]/1000, z[i]/1000
        u1, w1 = u[i], w[i]

        # modulo operator: ensures we are integrating around a closed loop (if i is the last point in the loop (i+1) would out of the range of points the modulo operator ensures it remains looped)
        j = (i+1) % n
        # store the second set of data
        x2, z2 = x[j]/1000, z[j]/1000
        u2, w2 = u[j], w[j]

        # estimate derivatives locally, by the difference
        dx = x2 - x1
        dz = z2 - z1

        #estimate contribution of velocity of a step by averages
        u_avg = (u1+u2)/2
        w_avg = (w1+w2)/2

        # compute gamma
        gamma = gamma + (dx*u_avg + dz*w_avg)

    # negative by counterclockwise positive definition of circulation
    return -gamma



