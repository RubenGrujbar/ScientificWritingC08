# import libraries
import numpy as np
import matplotlib.pyplot as plt
import pandas as pd


def circulation(x, z, u, w):
# this function calcultes the circulation by taking the line integral of the velocity field over the contour of the airfoil
# initiate circulation as gamma
    gamma = 0.0
    n = len(x)

    for i in range(n):
        # store the first data sets
        x1, z1 = x[i]/1000, z[i]/1000
        u1, w1 = u[i], w[i]

        # modulo operator: ensures we are integrating around a closed loop (if i is the last point in the loop (i+1) would out of the range of points the modulo operator ensures it remains looped)
        j = (i+1) % n
        # store the second set of data
        x2, z2 = x[j]/1000, z[j]/1000
        u2, w2 = u[j], w[j]

        # estimate derivatives locally, by the difference
        dx = x2 - x1
        dz = z2 - z1

        #estimate contribution of velocity of a step by averages
        u_avg = (u1+u2)/2
        w_avg = (w1+w2)/2

        # compute gamma
        gamma = gamma + (dx*u_avg + dz*w_avg)

    # negative by counterclockwise positive definition of circulation
    return -gamma



# constants
V_inf = 6.35 
rho_inf = 1.225

# FOR CONSTANT Y
# 1. Load data
df = pd.read_csv('Dataset NACA0015 Velocity and Standard deviation.csv')

target_y = 114.435
slice_df = df[np.isclose(df['y [mm]'], target_y, atol=0.001)].copy()

# 2. Separate valid points
u_eval_0 = slice_df.dropna(subset=['Velocity u [m/s]'])
w_eval_0 = slice_df.dropna(subset=['Velocity w [m/s]'])
x_eval_0 = slice_df.dropna(subset=['x [mm]'])
z_eval_0 = slice_df.dropna(subset=['z [mm]'])

#3. Define manually the target boundaries 
x_min = -52.1717
x_max = 150.296
z_min = -34.7677
z_max = 50.8919

boundaries_x = [x_min, x_max]
boundaries_z = [z_min, z_max]
circ_x = 0
# 4. Make slices at the four extremes 
for i in boundaries_x:
    slicex_slice_df = slice_df[np.isclose(slice_df[x_eval_0], boundaries_x[i], atol=0.001)].copy()
    u_eval_x = slicex_slice_df.dropna(subset=[u_eval_0])
    w_eval_x = slicex_slice_df.dropna(subset=[w_eval_0])
    z_eval_x = slicex_slice_df.dropna(subset=[z_eval_0])
    circ_x += circulation(slicex_slice_df, z_eval_x, u_eval_x, w_eval_x)
    

circ_z = 0
for j in boundaries_z:
    slicez_slice_df = slice_df[np.isclose(slice_df[z_eval_0], boundaries_z[j], atol=0.001)].copy()
    u_eval_z = slicez_slice_df.dropna(subset=[u_eval_0])
    w_eval_z = slicez_slice_df.dropna(subset=[w_eval_0])
    x_eval_z = slicez_slice_df.dropna(subset=[x_eval_0])
    circ_z += circulation(x_eval_z, slicez_slice_df, u_eval_z, w_eval_z)


circ_tot = circ_x + circ_z
lift = rho_inf*V_inf*circ_tot


print(lift)
