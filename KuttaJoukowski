        # Optional: equal scaling so units look correct
        plt.axis('equal')
        while target_y <= 450:
            target_y_list.append(target_y)
            lift_value = lift(target_y, boundaries_x, boundaries_z, rho_inf, V_inf)[0]
            lift_coeff = (2*lift_value)/(rho_inf*(V_inf**2)*0.1)
            lift_coeff_values.append(lift_coeff)
            target_y += step

        x_min_l -= stepsize * step
        x_max_l += stepsize * step    
        all_lift_coef_values.append(lift_coeff_values)
        
    z_min -= stepsize * step
    z_max += stepsize * step        



