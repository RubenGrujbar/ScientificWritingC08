    mse = np.mean((lift_coeff_values[mask] - NC15_interp[mask]) ** 2)
    print(f'Case {i}: MSE (y ∈ [0,1]) = {mse:.6e}')

    plt.plot(
        target_y_array[mask],
        lift_coeff_values[mask],
        color=color,
        label=(
            f'Case ('
            f'[{all_boundaries_x[i][0]:.2f}, {all_boundaries_x[i][1]:.2f}], '
            f'[{all_boundaries_z[i][0]:.2f}, {all_boundaries_z[i][1]:.2f}]'
            f') | MSE={mse:.2e}'
        )
    )

# Plot sorted reference (also masked)
ref_mask = (NC15_y_sorted >= 0) & (NC15_y_sorted <= 1)
plt.plot(NC15_y_sorted[ref_mask], NC15_m_sorted[ref_mask], 'r', label=r'$\alpha = 15^\circ$')

