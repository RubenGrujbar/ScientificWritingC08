#Circulation function, numerical line integral
def circulation(x, z, u, w):
    gamma = 0.0
    n = len(x)

    for i in range(n):
        # store the first data sets
        x1, z1 = x[i]/1000, z[i]/1000
        u1, w1 = u[i], w[i]

        # modulo operator: ensures we are integrating around a closed loop (if i is the last point in the loop (i+1) would out of the range of points the modulo operator ensures it remains looped)
        j = (i+1) % n
        # store the second set of data
        x2, z2 = x[j]/1000, z[j]/1000
        u2, w2 = u[j], w[j]

        # estimate derivatives locally, by the difference
        dx = x2 - x1
        dz = z2 - z1

        #estimate contribution of velocity of a step by averages
        u_avg = (u1+u2)/2
        w_avg = (w1+w2)/2

        # compute gamma
        gamma = gamma + (dx*u_avg + dz*w_avg)

    # negative by counterclockwise positive definition of circulation
    return -gamma

#Lift function
def lift(target_y, boundaries_x, boundaries_z, rho_inf, V_inf):

    #Slice the datafile such that we only look at a certain y-coordinate (span)
    slice_df = df[np.isclose(df['y [mm]'], target_y, atol=0.8)].copy()

    x_min, x_max = boundaries_x
    z_min, z_max = boundaries_z

    # ---- Create a rectangular boundary, consisting of 4 parts  ----

    #Bottom_cut goes from x_min to x_max at z_min (within a tolerance)
    bottom = slice_df[np.isclose(slice_df['z [mm]'], z_min, atol=1.5)].copy()
    bottom_cut = bottom[(bottom['x [mm]'] >= x_min-step) & (bottom['x [mm]'] < x_max+step)]

    #Right_cut goes from z_min to z_max at x_max (within a tolerance)
    right  = slice_df[np.isclose(slice_df['x [mm]'], x_max, atol=1.5)].copy()
    right_cut = right[(right['z [mm]'] >= z_min-step) & (right['z [mm]'] < z_max+step)]

    #Top_cut goes from x_min to x_max at z_max (within a tolerance)
    top    = slice_df[np.isclose(slice_df['z [mm]'], z_max, atol=1.5)].copy()
    top_cut = top[(top['x [mm]'] >= x_min-step) & (top['x [mm]'] < x_max+step)]

    #Left_cut goes from z_min to z_max at x_min (within a tolerance)
    left   = slice_df[np.isclose(slice_df['x [mm]'], x_min, atol=1.5)].copy()
    left_cut = left[(left['z [mm]'] >= z_min-step) & (left['z [mm]'] < z_max+step)]

    # ---- Clean NaNs ----
    def clean(df_part):
        return df_part.dropna(subset=[
            'Velocity u [m/s]',
            'Velocity w [m/s]',
            'x [mm]',
            'z [mm]'
        ])

    bottom_cut = clean(bottom_cut)
    right_cut  = clean(right_cut)
    top_cut    = clean(top_cut)
    left_cut   = clean(left_cut)

    # Sort edges
    bottom_cut = bottom_cut.sort_values('x [mm]')
    right_cut  = right_cut.sort_values('z [mm]')
    top_cut    = top_cut.sort_values('x [mm]', ascending=False)
    left_cut   = left_cut.sort_values('z [mm]', ascending=False)

    '''
    #Remove and store corner points, for now unused
    bottom_cut_corner = bottom_cut.iloc[1:-1]
    right_cut_corner = right_cut.iloc[1:-1]
    left_cut_corner = left_cut.iloc[1:-1]
    top_cut_corner = top_cut.iloc[1:-1]

    #Store corner points separately
    bottom_first = bottom_cut.iloc[0].copy
    bottom_last = bottom_cut.iloc[-1].copy
    
    right_first = right_cut.iloc[0].copy
    right_last = right_cut.iloc[-1].copy
    
    top_first = top_cut.iloc[0].copy
    top_last = top_cut.iloc[-1].copy
    
    left_first = left_cut.iloc[0].copy
    left_last = left_cut.iloc[-1].copy

    #Combine Corners
    # ---- Combine 8 corner pieces into ONE open loop ----
    #contour_corners = pd.concat([bottom_first, bottom_last, right_first, right_last, top_first, top_last, left_first, left_last])
    #print(np.shape(contour_corners))
    
    '''

    # Combine 4 straights into ONE open loop (for now including corners)
    contour_straights = pd.concat([bottom_cut, right_cut, top_cut, left_cut])
    print(np.shape(contour_straights))
   

    # ---- Compute circulation of 4 straights ----
    gamma_straight = circulation(
        contour_straights['x [mm]'].values,
        contour_straights['z [mm]'].values,
        contour_straights['Velocity u [m/s]'].values,
        contour_straights['Velocity w [m/s]'].values
    )

    # ---- Compute circulation of 8 corners ----

    # Convert to lift
    lift = -rho_inf * V_inf * gamma_straight
    return lift, bottom_cut['x [mm]'], bottom_cut['z [mm]'], right_cut['x [mm]'], right_cut['z [mm]'], top_cut['x [mm]'], top_cut['z [mm]'], left_cut['x [mm]'], left_cut['z [mm]']

#Execute the lift calculation for varying boundaries over the whole span, including creation of contour plots
plt.figure()
colors = plt.cm.viridis(np.linspace(0, 1, n_steps_x * n_steps_z))
color_idx = 0
all_lift_coef_values = []
all_boundaries_x = []
all_boundaries_z = []
for _ in range(n_steps_z):
    boundaries_z = [z_min, z_max]
    x_min_l = x_min
    x_max_l = x_max
     
    for _ in range(n_steps_x):
        lift_coeff_values = []
        boundaries_x = [x_min_l, x_max_l]
        all_boundaries_x.append(boundaries_x)
        all_boundaries_z.append(boundaries_z) 
        #Loop over the whole span
        target_y = 101.457 #mm, starting y_point
