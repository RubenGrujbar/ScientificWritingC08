def circulation(x, z, u, w):
    gamma = 0.0
    n = len(x)

    for i in range(n):
        # store the first data sets
        x1, z1 = x[i]/1000, z[i]/1000
        u1, w1 = u[i], w[i]

        # modulo operator: ensures we are integrating around a closed loop (if i is the last point in the loop (i+1) would out of the range of points the modulo operator ensures it remains looped)
        j = (i+1) % n
        # store the second set of data
        x2, z2 = x[j]/1000, z[j]/1000
        u2, w2 = u[j], w[j]

        # estimate derivatives locally, by the difference
        dx = x2 - x1
        dz = z2 - z1

        #estimate contribution of velocity of a step by averages
        u_avg = (u1+u2)/2
        w_avg = (w1+w2)/2

        # compute gamma
        gamma = gamma + (dx*u_avg + dz*w_avg)

    # negative by counterclockwise positive definition of circulation
    return -gamma

def lift(target_y, boundaries_x, boundaries_z, rho_inf, V_inf):

    #Slice the datafile such that we only look at a certain y-coordinate (span)
    slice_df = df[np.isclose(df['y [mm]'], target_y, atol=0.8)].copy()

    x_min, x_max = boundaries_x
    z_min, z_max = boundaries_z

    # ---- Create a rectangular boundary, consisting of 4 parts  ----

    #Bottom_cut goes from x_min to x_max at z_min (whithin a tolerance)
    bottom = slice_df[np.isclose(slice_df['z [mm]'], z_min, atol=1.5)].copy()
    bottom_cut = bottom[(bottom['x [mm]'] >= x_min) & (bottom['x [mm]'] < x_max)]

    #Right_cut goes from z_min to z_max at x_max (whithin a tolerance)
    right  = slice_df[np.isclose(slice_df['x [mm]'], x_max, atol=1.5)].copy()
    right_cut = right[(right['z [mm]'] >= z_min) & (right['z [mm]'] < z_max)]

    #Top_cut goes from x_min to x_max at z_max (whithin a tolerance)
    top    = slice_df[np.isclose(slice_df['z [mm]'], z_max, atol=1.5)].copy()
    top_cut = top[(top['x [mm]'] >= x_min) & (top['x [mm]'] < x_max)]

    #Left_cut goes from z_min to z_max at x_min (whithin a tolerance)
    left   = slice_df[np.isclose(slice_df['x [mm]'], x_min, atol=1.5)].copy()
    left_cut = left[(left['z [mm]'] >= z_min) & (left['z [mm]'] < z_max)]

    # ---- Clean NaNs ----
    def clean(df_part):
        return df_part.dropna(subset=[
            'Velocity u [m/s]',
            'Velocity w [m/s]',
            'x [mm]',
            'z [mm]'
        ])

    bottom_cut = clean(bottom_cut)
    right_cut  = clean(right_cut)
    top_cut    = clean(top_cut)
    left_cut   = clean(left_cut)

    # ---- Sort edges (IMPORTANT for correct direction) ----
    bottom_cut = bottom_cut.sort_values('x [mm]')
    right_cut  = right_cut.sort_values('z [mm]')
    top_cut    = top_cut.sort_values('x [mm]', ascending=False)
    left_cut   = left_cut.sort_values('z [mm]', ascending=False)

    #Remove corner points
    bottom_cut_corner = bottom_cut.iloc[1:-1]
    right_cut_corner = right_cut.iloc[1:-1]
    left_cut_corner = left_cut.iloc[1:-1]
    top_cut_corner = top_cut.iloc[1:-1]

    #Store corner points separately
    bottom_first = bottom_cut.iloc[0].copy
    bottom_last = bottom_cut.iloc[-1].copy
    
    right_first = right_cut.iloc[0].copy
    right_last = right_cut.iloc[-1].copy
    
    top_first = top_cut.iloc[0].copy
    top_last = top_cut.iloc[-1].copy
    
    left_first = left_cut.iloc[0].copy
    left_last = left_cut.iloc[-1].copy

    # ---- Combine 4 straights into ONE open loop ----
    contour_straights = pd.concat([bottom_cut_corner, right_cut_corner, top_cut_corner, left_cut_corner])
    contour = pd.concat([bottom_cut, right_cut, top_cut, left_cut])
    # print(np.shape(contour_straights))

    # ---- Combine 8 corner pieces into ONE open loop ----
    #contour_corners = pd.concat([bottom_first, bottom_last, right_first, right_last, top_first, top_last, left_first, left_last])
    #print(np.shape(contour_corners))

    # ---- Compute circulation of 4 straights ----
    gamma_straight = circulation(
        contour_straights['x [mm]'].values,
        contour_straights['z [mm]'].values,
        contour_straights['Velocity u [m/s]'].values,
        contour_straights['Velocity w [m/s]'].values
    )

    gamma = circulation(
        contour['x [mm]'].values,
        contour['z [mm]'].values,
        contour['Velocity u [m/s]'].values,
        contour['Velocity w [m/s]'].values
    )

    # ---- Compute circulation of 8 corners ----

    # Convert to lift
    lift = -rho_inf * V_inf * gamma_straight
    return lift

file_path = os.path.join(os.getcwd(), 'Dataset NACA0015 Velocity and Standard deviation.csv')

if not os.path.exists(file_path):
    raise FileNotFoundError(f"File not found at: {file_path}")

df = pd.read_csv(file_path)
x_unique = np.unique(df['x [mm]'])
z_unique = np.unique(df['z [mm]'])


chord = 100
step = 2.596 #mm

n_steps_x = 20
n_steps_z = 20


x_max_start = 100
x_min_start = 0
z_max_start = 30
z_min_start = -10

x_max_end = 200
x_min_end = -100
z_max_end = 90 
z_min_end = -60


x_max_targets = np.linspace(x_max_start, x_max_end, n_steps_x)
x_min_targets = np.linspace(x_min_start, x_min_end, n_steps_x)
z_max_targets = np.linspace(z_max_start, z_max_end, n_steps_z)
z_min_targets = np.linspace(z_min_start, z_min_end, n_steps_z)

def snap_to_nearest(targets, actual_values):
    snapped = np.array([actual_values[np.argmin(np.abs(actual_values - t))] for t in targets ])
    return snapped

x_min_values = snap_to_nearest(x_min_targets, x_unique)
x_max_values = snap_to_nearest(x_max_targets, x_unique)
z_min_values = snap_to_nearest(z_min_targets, z_unique)
z_max_values = snap_to_nearest(z_max_targets, z_unique)

x_axis = (x_max_values - x_min_values)/chord
z_axis = (z_max_values - z_min_values)/chord

CL_grid = np.full((n_steps_x, n_steps_z), np.nan)
V_inf = 6.35 #m/s
rho_inf = 1.204 #kg/m^3

for i in range(n_steps_x):
    for k in range(n_steps_z):
        boundaries_x = [x_min_values[i], x_max_values[i]]
        boundaries_z = [z_min_values[k], z_max_values[k]]

        cl_span = []
        target_y = 101.457 #mm, starting y_point
        while target_y <= 450:
            print(i, k)
            lift_value = lift(target_y, boundaries_x, boundaries_z, rho_inf, V_inf)
            lift_coeff = (2*lift_value)/(rho_inf*(V_inf**2)*0.1)
            cl_span.append(lift_coeff)
            target_y += step 
            

        CL_grid[i,k] =  np.mean(cl_span)


X_mesh, Z_mesh = np.meshgrid(x_axis, z_axis, indexing = 'ij')

fig = plt.figure()
ax = fig.add_subplot(111, projection='3d')

surf = ax.plot_surface(
    X_mesh, Z_mesh, CL_grid,
    cmap='RdYlGn',
    edgecolor='k',
    linewidth=0.3,
    alpha=0.95
)

fig.colorbar(surf, ax=ax, shrink=0.5, label='$C_L$ [-]')
ax.set_xlabel('Contour width x/c [-]')
ax.set_ylabel('Contour height z/c [-]')
ax.set_zlabel('Lift coefficient $C_L$ [-]')

